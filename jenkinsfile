@Library("my-shared-library") _

pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = "dockerHubCred"
        FRONTEND_IMAGE = "aiml074/frontend"
        BACKEND_IMAGE = "aiml074/backend"
        SONAR_CREDENTIALS = "sonarqube"
        PROJECT_KEY = "fullstack-devops-lab"
        SONAR_URL = "http://172.23.203.6:9000"
        EMAIL_RECEIPENT = "rpsingh98188@gmail.com"
    }

    stages {
        stage("Clone Code") {
             steps {
                git url: "https://github.com/Rudra392-netizen/fullstack-devops-lab.git", branch: "main"
            }
        }

        stage("Install Dependencies") {
            steps {
                installNode("Application-Code/backend")
            }
        }

        stage("Unit Testing") {
            steps {
                runTest("Application-Code/backend")
            }
        }

        stage("SonarQube Analysis") {
            steps {
                runSonarQube(
                    "Application-Code/backend",
                    env.PROJECT_KEY,
                    env.SONAR_URL,
                    env.SONAR_CREDENTIALS
                )
            }
        }

        stage("Quality Gate") {
            steps {
                qualityGate()
            }
        }

        stage("Build Docker Image") {
            steps {
                buildwithDocker(env.FRONTEND_IMAGE, "Application-Code/frontend")
                buildwithDocker(env.BACKEND_IMAGE, "Application-Code/backend")
            }
        }

        stage("Trivy Scan") {
            steps {
                runTrivy(env.FRONTEND_IMAGE)
                runTrivy(env.BACKEND_IMAGE)
            }
        }

        stage("Push Docker Image") {
            steps {
                pushToDockerHub(env.FRONTEND_IMAGE, env.DOCKERHUB_CREDENTIALS)
                pushToDockerHub(env.BACKEND_IMAGE, env.DOCKERHUB_CREDENTIALS)
            }
        }

        stage("Deploy to K8s") {
            steps {
                k8deploy("K8s/")
            }
        }
    }

    post {
        always {
            emailNotification(env.EMAIL_RECEIPENT)
        }
    }
}